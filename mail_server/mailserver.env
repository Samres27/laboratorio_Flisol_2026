# OVERRIDE_HOSTNAME=mail.vulnlab.bo
# ENABLE_FAIL2BAN=1
# ENABLE_SPAMASSASSIN=1
# ENABLE_CLAMAV=0
# SSL_TYPE=
# POSTFIX_MESSAGE_SIZE_LIMIT=52428800
# POSTSCREEN_ACTION=ignore
# PERMIT_DOCKER=connected-networks

# mailserver.env - Versión MINIMALISTA
OVERRIDE_HOSTNAME=mail.vulnlab.bo

# Servicios DESACTIVADOS para máxima velocidad
ENABLE_FAIL2BAN=0
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_AMAVIS=0
ENABLE_POSTGREY=0
ENABLE_UPDATE_CHECK=0
ENABLE_QUOTAS=0

# Servicios ACTIVADOS (solo lo necesario)
ENABLE_IMAP=1
ENABLE_AUTH=1

# Red (CORRECTO)
PERMIT_DOCKER=connected-networks

# SSL deshabilitado
SSL_TYPE=

# Límites
POSTFIX_MESSAGE_SIZE_LIMIT=52428800
POSTSCREEN_ACTION=ignore

# Timeouts cortos
POSTFIX_smtpd_timeout=10
POSTFIX_connect_timeout=10

# Logging
#LOG_LEVEL=info
# Nivel de verbose (menos detalle)
defer_transports = 
disable_verp = yes

# Reducir logs de conexiones
smtpd_helo_required = no
disable_vrfy_command = yes